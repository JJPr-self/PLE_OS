# ── PLEASUREDAI OS — Environment Variables ──────────────────────────────────
# Copy this to .env and customize for your deployment

# Authentication (CHANGE THESE FOR PRODUCTION!)
AUTH_USERNAME=nerv
AUTH_PASSWORD=genesis
AUTH_TOKEN=

# HuggingFace token (required for gated models like WAN 2.2)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# vast.ai will inject these automatically (do not set manually):
# PUBLIC_IPADDR=
# VAST_TCP_PORT_80=
# VAST_TCP_PORT_8188=
# VAST_TCP_PORT_3000=
